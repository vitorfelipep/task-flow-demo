{
  "name": "@taskflow/database",
  "version": "0.1.0",
  "private": true,
  "description": "Database schema and client for TaskFlow",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.9.0"
  },
  "devDependencies": {
    "@taskflow/config": "*",
    "prisma": "^5.9.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
